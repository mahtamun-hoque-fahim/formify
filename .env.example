# Database — Neon (get both from Neon dashboard)
DATABASE_URL=postgresql://...?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://...?sslmode=require

# Auth — Better Auth
BETTER_AUTH_SECRET=                   # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000  # change to production URL on deploy

# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email — Resend
RESEND_API_KEY=re_...

# Media — Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate limiting — Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin — comma-separated emails that get admin role on first login
ADMIN_EMAILS=your@email.com

# Payments — STUBBED, do not fill until public launch
# LEMON_SQUEEZY_API_KEY=
# LEMON_SQUEEZY_WEBHOOK_SECRET=
